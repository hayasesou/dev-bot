{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanV2",
  "type": "object",
  "required": ["version", "goal", "acceptance_criteria", "candidate_files"],
  "properties": {
    "version": {"type": "integer"},
    "goal": {"type": "string"},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "candidate_files": {"type": "array", "items": {"type": "string"}},
    "must_not_touch": {"type": "array", "items": {"type": "string"}},
    "verification_focus": {"type": "array", "items": {"type": "string"}},
    "exploration_required": {"type": "boolean"},
    "tasks": {"type": "array"},
    "design_branches": {"type": "array"},
    "risks": {"type": "array"},
    "test_mapping": {"type": "array"},
    "verification_profile": {"type": "string"},
    "planner_confidence": {"type": "number"}
  },
  "additionalProperties": true
}
